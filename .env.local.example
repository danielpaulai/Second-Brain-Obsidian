# --- AI provider (pick one) ---
# Recommended: Vercel AI Gateway (one key, any model)
AI_GATEWAY_API_KEY=

# Or direct providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Default model (uses gateway format: "provider/model")
AI_MODEL=anthropic/claude-sonnet-4-6

# --- Your brain ---
# Absolute path to your Obsidian vault
VAULT_PATH=/Users/danielpaul/Documents/Obsidian/Obsidian Vault

# Folders to exclude when reading the vault (comma-separated)
VAULT_EXCLUDE=.obsidian,.trash,node_modules
