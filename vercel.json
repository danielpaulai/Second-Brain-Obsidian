{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "pnpm install --prod=false",
  "functions": {
    "src/app/api/chat/route.ts": { "maxDuration": 90, "memory": 1024 },
    "src/app/api/brain/reindex/route.ts": { "maxDuration": 300, "memory": 2048 },
    "src/app/api/brain/search/route.ts": { "maxDuration": 30, "memory": 1024 },
    "src/app/api/brain/note/route.ts": { "maxDuration": 15, "memory": 512 },
    "src/app/api/knowledge/route.ts": { "maxDuration": 15, "memory": 512 },
    "src/app/api/cron/morning-brief/route.ts": { "maxDuration": 120, "memory": 1024 },
    "src/app/api/cron/weekly-review/route.ts": { "maxDuration": 120, "memory": 1024 },
    "src/app/api/brief/pre-call/route.ts": { "maxDuration": 90, "memory": 1024 },
    "src/app/api/draft/generate/route.ts": { "maxDuration": 90, "memory": 1024 },
    "src/app/api/capture/meeting/route.ts": { "maxDuration": 60, "memory": 1024 },
    "src/app/api/cron/librarian/route.ts": { "maxDuration": 300, "memory": 1024 }
  },
  "crons": [
    {
      "path": "/api/cron/morning-brief",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/weekly-review",
      "schedule": "0 17 * * 0"
    },
    {
      "path": "/api/cron/librarian",
      "schedule": "0 2 * * *"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Content-Type", "value": "application/manifest+json" },
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
